CAD_API_PORT=4000
CAD_MAX_UPLOAD_MB=100
DWG_CONVERTER_TIMEOUT_MS=120000
ODA_OUTPUT_VERSION=ACAD2018

# Allow your frontend origins in production.
# Examples:
# CAD_ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
CAD_ALLOWED_ORIGINS=http://localhost:5173

# Railway / Docker default:
# Dockerfile.cad-api already installs LibreDWG (dwg2dxf), so no extra converter path is required.
# Use DWG2DXF_PATH only if your dwg2dxf binary is in a non-standard location.
# DWG2DXF_PATH=/usr/bin/dwg2dxf

# Optional local Windows fallback:
# ODA_FILE_CONVERTER_PATH=C:/Program Files/ODA/ODAFileConverter/ODAFileConverter.exe

# Optional custom converter command template:
# DWG_CONVERTER_COMMAND=/usr/local/bin/your-converter --input {inputPath} --output {outputDxfPath}
