CAD_API_PORT=4000
CAD_MAX_UPLOAD_MB=100
DWG_CONVERTER_TIMEOUT_MS=120000
ODA_OUTPUT_VERSION=ACAD2018

# Allow your frontend origins in production.
# Examples:
# CAD_ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
CAD_ALLOWED_ORIGINS=http://localhost:5173

# Choose one converter strategy.
# 1) Installed converter executable path on the server/container host:
ODA_FILE_CONVERTER_PATH=/opt/oda/ODAFileConverter

# 2) Or a custom conversion command template instead:
# DWG_CONVERTER_COMMAND=/usr/local/bin/your-converter --input {inputPath} --output {outputDxfPath}
